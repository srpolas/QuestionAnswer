@model QuestionAnswer.Web.Models.QuestionDetailsViewModel
@{
    ViewData["Title"] = Model.Title;
}

<div class="mb-3">
    <a asp-controller="Home" asp-action="Index" class="text-decoration-none">&larr; Back to questions</a>
</div>

@* Main question with voting *@
<div class="card mb-4">
    <div class="card-body d-flex">
        @if (User.Identity?.IsAuthenticated ?? false)
        {
            <div class="d-flex flex-column align-items-center me-3">
                <form asp-controller="Vote" asp-action="Question" method="post" class="mb-0">
                    <input type="hidden" name="questionId" value="@Model.QuestionId" />
                    <input type="hidden" name="up" value="true" />
                    <input type="hidden" name="returnQuestionId" value="@Model.QuestionId" />
                    <button type="submit" class="btn btn-link p-0 text-secondary" title="Upvote">▲</button>
                </form>
                <span class="fw-semibold">@Model.QuestionScore</span>
                <form asp-controller="Vote" asp-action="Question" method="post" class="mb-0">
                    <input type="hidden" name="questionId" value="@Model.QuestionId" />
                    <input type="hidden" name="up" value="false" />
                    <input type="hidden" name="returnQuestionId" value="@Model.QuestionId" />
                    <button type="submit" class="btn btn-link p-0 text-secondary" title="Downvote">▼</button>
                </form>
            </div>
        }
        else
        {
            <div class="d-flex flex-column align-items-center me-3 text-muted">
                <span>▲</span>
                <span class="fw-semibold">@Model.QuestionScore</span>
                <span>▼</span>
            </div>
        }
        <div class="flex-grow-1">
            <h1 class="card-title h3">@Model.Title</h1>
            <p class="text-muted small mb-2">
                Asked @Model.CreatedAt.ToString("dd MMM yyyy 'at' HH:mm") &middot; @Model.ViewCount views &middot; in @Model.CategoryName
                @if (Model.TagNames.Any())
                {
                    <span> &middot; @string.Join(", ", Model.TagNames)</span>
                }
            </p>
            <p class="mb-0">@Model.Description</p>
            <p class="text-muted small mt-2 mb-0">By @Model.AuthorName</p>

            @if (User.Identity?.Name == Model.AuthorName)
            {
                <div class="mt-2">
                    <a asp-action="Edit" asp-route-id="@Model.QuestionId" class="btn btn-sm btn-outline-primary">Edit</a>
                    <form asp-action="Delete" asp-route-id="@Model.QuestionId" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this question?');">
                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                    </form>
                </div>
            }
        </div>
    </div>
</div>

<h5 class="mb-3">@Model.Answers.Count Answer(s)</h5>

@if (Model.Answers.Any())
{
    @foreach (var answer in Model.Answers)
    {
        <div class="card mb-3 @(answer.IsAccepted ? "border-success" : "")">
            @if (answer.IsAccepted)
            {
                <div class="card-header bg-success text-white py-1 small">Accepted Answer</div>
            }
            <div class="card-body d-flex">
                <div class="d-flex flex-column align-items-center me-3">
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <form asp-controller="Vote" asp-action="Answer" method="post" class="mb-0">
                            <input type="hidden" name="answerId" value="@answer.AnswerId" />
                            <input type="hidden" name="up" value="true" />
                            <input type="hidden" name="questionId" value="@Model.QuestionId" />
                            <button type="submit" class="btn btn-link p-0 text-secondary" title="Upvote">▲</button>
                        </form>
                        <span class="fw-semibold">@answer.Score</span>
                        <form asp-controller="Vote" asp-action="Answer" method="post" class="mb-0">
                            <input type="hidden" name="answerId" value="@answer.AnswerId" />
                            <input type="hidden" name="up" value="false" />
                            <input type="hidden" name="questionId" value="@Model.QuestionId" />
                            <button type="submit" class="btn btn-link p-0 text-secondary" title="Downvote">▼</button>
                        </form>
                    }
                    else
                    {
                        <span>▲</span>
                        <span class="fw-semibold">@answer.Score</span>
                        <span>▼</span>
                    }

                    @if (User.Identity?.Name == Model.AuthorName && !answer.IsAccepted)
                    {
                        <form asp-action="AcceptAnswer" method="post" class="mt-2">
                            <input type="hidden" name="id" value="@answer.AnswerId" />
                            <input type="hidden" name="questionId" value="@Model.QuestionId" />
                            <button type="submit" class="btn btn-sm btn-outline-success" title="Accept this answer">✔</button>
                        </form>
                    }
                </div>
                <div class="flex-grow-1">
                    <p class="mb-0">@answer.Content</p>
                    <p class="text-muted small mt-2 mb-0">
                        @answer.AuthorName &middot; @answer.CreatedAt.ToString("dd MMM yyyy HH:mm")
                        @if (User.Identity?.Name == answer.AuthorName)
                        {
                            <span> &middot; </span>
                            <a href="javascript:void(0)" onclick="document.getElementById('edit-answer-@answer.AnswerId').classList.toggle('d-none')" class="text-decoration-none">Edit</a>
                            <span> &middot; </span>
                            <form asp-action="DeleteAnswer" asp-route-id="@answer.AnswerId" asp-route-questionId="@Model.QuestionId" method="post" class="d-inline" onsubmit="return confirm('Delete this answer?');">
                                <button type="submit" class="btn btn-link p-0 text-danger text-decoration-none border-0 small" style="vertical-align: baseline;">Delete</button>
                            </form>
                        }
                    </p>

                    @* Edit Answer Inline Form *@
                    <div id="edit-answer-@answer.AnswerId" class="d-none mt-2">
                        <form asp-action="EditAnswer" method="post">
                            <input type="hidden" name="id" value="@answer.AnswerId" />
                            <input type="hidden" name="questionId" value="@Model.QuestionId" />
                            <textarea name="content" class="form-control mb-2">@answer.Content</textarea>
                            <button type="submit" class="btn btn-sm btn-primary">Save</button>
                            <button type="button" onclick="document.getElementById('edit-answer-@answer.AnswerId').classList.add('d-none')" class="btn btn-sm btn-secondary">Cancel</button>
                        </form>
                    </div>

                    @* Comments Section *@
                    <div class="mt-3 ps-4 border-start">
                        <h6 class="small fw-bold">Comments</h6>
                        @foreach (var comment in answer.Comments)
                        {
                            <div class="small mb-1 pb-1 border-bottom">
                                <span>@comment.Content</span>
                                <span class="text-muted">&mdash; @comment.AuthorName</span>
                                @if (User.Identity?.Name == comment.AuthorName)
                                {
                                    <form asp-action="DeleteComment" asp-route-id="@comment.CommentId" asp-route-questionId="@Model.QuestionId" method="post" class="d-inline float-end" onsubmit="return confirm('Delete comment?');">
                                        <button type="submit" class="btn btn-link p-0 text-danger text-decoration-none border-0 smaller" style="font-size: 0.75rem;">Delete</button>
                                    </form>
                                }
                            </div>
                        }
                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            <form asp-action="AddComment" method="post" class="mt-2">
                                <input type="hidden" name="answerId" value="@answer.AnswerId" />
                                <input type="hidden" name="questionId" value="@Model.QuestionId" />
                                <div class="input-group input-group-sm">
                                    <input type="text" name="content" class="form-control" placeholder="Add a comment..." required />
                                    <button type="submit" class="btn btn-outline-secondary">Post</button>
                                </div>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
}
else
{
    <p class="text-muted">No answers yet. Be the first to answer!</p>
}

@if (User.Identity?.IsAuthenticated ?? false)
{
    <div class="card mt-4">
        <div class="card-header">
            <h6 class="mb-0">Your Answer</h6>
        </div>
        <div class="card-body">
            @if (TempData["AnswerError"] != null)
            {
                <div class="alert alert-warning">@TempData["AnswerError"]</div>
            }
            <form asp-controller="Question" asp-action="AddAnswer" method="post">
                <input type="hidden" name="QuestionId" value="@Model.QuestionId" />
                <div class="mb-3">
                    <textarea name="Content" class="form-control" rows="4" placeholder="Write your answer..."></textarea>
                    <span class="text-danger field-validation-valid" data-valmsg-for="Content" data-valmsg-replace="true"></span>
                </div>
                <button type="submit" class="btn btn-primary">Post Answer</button>
            </form>
        </div>
    </div>
}
else
{
    <div class="alert alert-info mt-4">
        <a asp-controller="Account" asp-action="Login" asp-route-returnUrl="@Context.Request.Path">Log in</a> to post an answer or vote.
    </div>
}
